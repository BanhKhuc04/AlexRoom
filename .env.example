# Copy values into the service environment. Never commit real secrets.
ALEX_API_KEY=replace-with-a-long-local-key
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=alex_core
MQTT_PASSWORD=replace-with-broker-password
# Optional stable production identity. Parallel previews should leave this unset.
# MQTT_CLIENT_ID=alex-core-orange-pi
ALEX_SIMULATOR=0
ALEX_MUTATION_RATE_LIMIT=30
ALEX_BRAIN_MAC=
ALEX_BRAIN_HOST=
ALEX_BRAIN_PORT=22
ALEX_DATABASE_PATH=./data/alex.db
