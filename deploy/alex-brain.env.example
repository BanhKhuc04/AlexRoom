# Copy to /etc/alex/alex-brain.env and set a strong private value.
ALEX_BRAIN_API_KEY=

ALEX_BRAIN_PROVIDER=ollama_native
ALEX_BRAIN_PROVIDER_URL=http://127.0.0.1:11434
ALEX_BRAIN_MODEL=qwen3.5:2b
ALEX_BRAIN_PROVIDER_API_KEY=

# Normal inference must fail before the Core's 30-second request budget.
ALEX_BRAIN_PROVIDER_TIMEOUT_SECONDS=25

# Startup-only cold loading is measured separately and may take ~46.66 seconds.
ALEX_BRAIN_WARMUP_TIMEOUT_SECONDS=60
