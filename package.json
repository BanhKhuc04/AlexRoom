{
  "name": "alexroom-mark-iii",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint static tests scripts eslint.config.js",
    "test": "node --test tests/*.test.mjs",
    "test:backend": "python -m unittest discover -s tests -p \"test_*.py\" -v",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "check:all": "npm run check && npm run test:backend && python -m py_compile app.py alex_store.py alex_safety.py alex_hardware.py alex_simulator.py alex_orchestration.py alex_brain.py",
    "preview:windows": "powershell -ExecutionPolicy Bypass -File scripts/preview.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "typescript": "^5.9.0"
  }
}
